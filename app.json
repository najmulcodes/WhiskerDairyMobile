{
  "expo": {
    "name": "Whisker Dairy",
    "slug": "whiskerdairy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fff8f4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.whiskerdairy.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to take pet photos",
        "NSPhotoLibraryUsageDescription": "Used to pick pet photos from your library",
        "NSUserNotificationsUsageDescription": "Used to send reminders for pet care"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fff8f4"
      },
      "package": "com.whiskerdairy.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Whisker Dairy to access your photos to set pet images.",
          "cameraPermission": "Allow Whisker Dairy to use the camera to take pet photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ff7a5c"
        }
      ],
      "./plugins/withAndroidBuildFixes"
    ],
    "scheme": "whiskerdairy",
    "extra": {
      "eas": {
        "projectId": "74b6c349-569a-46ab-8111-41037b82f3e4"
      }
    },
    "owner": "najmulcodes"
  }
}
